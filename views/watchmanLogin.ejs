<%- include('partials/header') %>
    <div class="container" style="padding: 40px 0;">
        <div class="glass-panel" style="max-width: 400px; margin: auto; padding: 40px; text-align: center;">
            <h2 style="margin-bottom: 30px; color: var(--primary);">Watchman Login</h2>
            <form action="/watchman/login" method="POST" class="glass-form">
                <div class="form-group" style="text-align: left;">
                    <label>Email</label>
                    <input class="form-control" type="email" name="username" required />
                </div>
                <div class="form-group" style="text-align: left;">
                    <label>Password</label>
                    <input class="form-control" type="password" name="password" required />
                </div>
                <button class="glass-btn" style="width: 100%; margin-top: 20px;" type="submit">Login</button>
            </form>
            <p style="margin-top: 20px; color: var(--text-muted);">New watchman? <a href="/watchman/signup"
                    style="color: var(--accent);">Create account</a></p>
        </div>
    </div>
    <%- include('partials/footer') %>