<%- include('partials/header') %>
    <div class="container" style="padding: 40px 0;">
        <div class="glass-panel" style="max-width: 500px; margin: auto; padding: 40px;">
            <h2 class="text-center" style="margin-bottom: 30px; color: var(--primary);">Watchman Signup</h2>
            <form action="/watchman/signup" method="POST" class="glass-form">
                <div class="form-group">
                    <label>Email</label>
                    <input class="form-control" type="email" name="username" required />
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <input class="form-control" type="password" name="password" required />
                </div>
                <div class="row">
                    <div class="col-md-6 form-group">
                        <label>First Name</label>
                        <input class="form-control" type="text" name="firstName" />
                    </div>
                    <div class="col-md-6 form-group">
                        <label>Last Name</label>
                        <input class="form-control" type="text" name="lastName" />
                    </div>
                </div>
                <div class="form-group">
                    <label>Phone</label>
                    <input class="form-control" type="number" name="phoneNumber" required />
                </div>
                <div class="form-group">
                    <label>Society</label>
                    <select class="form-control" name="societyName" required>
                        <% (societies||[]).forEach(function(s){ %>
                            <option value="<%= s.societyName %>">
                                <%= s.societyName %>
                            </option>
                            <% }) %>
                    </select>
                </div>
                <div class="form-group">
                    <label>Flat (optional)</label>
                    <input class="form-control" type="text" name="flatNumber" placeholder="e.g. GATE" />
                </div>
                <button class="glass-btn" style="width: 100%; margin-top: 20px;" type="submit">Create Watchman</button>
            </form>
            <p style="margin-top: 20px; text-align: center; color: var(--text-muted);">Already have an account? <a
                    href="/watchman/login" style="color: var(--accent);">Login</a></p>
        </div>
    </div>
    <%- include('partials/footer') %>