<%- include('partials/header') %>
    <div class="container" style="padding: 40px 0;">
        <div style="text-align: center; margin-bottom: 40px;">
            <h2 style="text-transform: uppercase;">Watchman Panel</h2>
        </div>

        <div class="glass-panel"
            style="padding: 30px; margin-bottom: 40px; max-width: 600px; margin-left: auto; margin-right: auto;">
            <h3 style="color: var(--primary); margin-bottom: 20px; text-align: center;">New Visitor Entry</h3>
            <form action="/gate/request" method="POST" class="glass-form">
                <div class="form-grid">
                    <div class="form-group">
                        <label>Flat Number</label>
                        <input class="form-control" type="text" name="flatNumber" required placeholder="e.g. A-101" />
                    </div>
                    <div class="form-group">
                        <label>Visitor Name</label>
                        <input class="form-control" type="text" name="visitorName" required placeholder="John Doe" />
                    </div>
                    <div class="form-group">
                        <label>Purpose</label>
                        <select class="form-control" name="purpose" required>
                            <option value="guest">Guest</option>
                            <option value="delivery">Delivery</option>
                            <option value="maintenance">Maintenance</option>
                            <option value="other">Other</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Notes</label>
                        <input class="form-control" type="text" name="notes" placeholder="Optional details" />
                    </div>
                </div>
                <div class="form-actions" style="margin-top: 20px; text-align: center;">
                    <button class="glass-btn" style="width: 100%;" type="submit">Send Approval Request</button>
                </div>
            </form>
        </div>

        <div class="glass-panel" style="padding: 30px;">
            <h3
                style="color: var(--accent); margin-bottom: 20px; border-bottom: 1px solid var(--glass-border); padding-bottom: 10px;">
                Recent Activity</h3>
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Time</th>
                            <th>Flat</th>
                            <th>Visitor</th>
                            <th>Purpose</th>
                            <th>Status</th>
                            <th>Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(requests && requests.length){ %>
                            <% requests.forEach(function(r){ %>
                                <tr>
                                    <td>
                                        <%= new Date(r.createdAt).toLocaleString() %>
                                    </td>
                                    <td><span class="badge badge-primary">
                                            <%= r.residentFlatNumber %>
                                        </span></td>
                                    <td>
                                        <%= r.visitorName %>
                                    </td>
                                    <td>
                                        <%= r.purpose %>
                                    </td>
                                    <td>
                                        <% if(r.status==='approved' ) { %>
                                            <span class="badge badge-success">Approved</span>
                                            <% } else if(r.status==='rejected' ) { %>
                                                <span class="badge badge-danger">Rejected</span>
                                                <% } else { %>
                                                    <span class="badge badge-warning">Pending</span>
                                                    <% } %>
                                    </td>
                                    <td>
                                        <%= r.notes || '-' %>
                                    </td>
                                </tr>
                                <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="6" class="text-center text-muted">No entries found</td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <%- include('partials/footer') %>